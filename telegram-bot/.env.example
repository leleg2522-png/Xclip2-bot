TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
RENDERFUL_API_KEY=your_renderful_api_key_here
# Optional: public base URL used to build download links for large results.
# On Railway, RAILWAY_PUBLIC_DOMAIN is set automatically and used by default.
# Set PUBLIC_BASE_URL only to override it (e.g. a custom domain). No trailing slash.
PUBLIC_BASE_URL=
